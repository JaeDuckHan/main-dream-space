{
  "name": "dreamspace-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "node scripts/run-sql.mjs migrations/001_init.sql migrations/003_oauth.sql migrations/004_listings.sql migrations/004b_migrate_accommodations.sql migrations/005_community.sql migrations/006_residents_patch.sql migrations/012_planner_plans.sql",
    "seed": "node scripts/run-sql.mjs seeds/checklist.seed.sql seeds/listings.seed.sql",
    "import:listings": "node scripts/import-listings.mjs",
    "import:notion": "node scripts/notion-import.mjs",
    "cleanup:images": "tsx src/cron/cleanup-orphan-images.ts"
  },
  "dependencies": {
    "@notionhq/client": "^5.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "isomorphic-dompurify": "^3.8.0",
    "marked": "^18.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "notion-to-md": "^3.1.9",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "resend": "^6.11.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node-cron": "^3.0.11",
    "@types/express": "^5.0.3",
    "@types/node": "^22.16.5",
    "@types/papaparse": "^5.3.16",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
